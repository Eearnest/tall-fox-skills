{
  "name": "dalle",
  "version": "0.1.0",
  "description": "Generate images from text prompts using OpenAI DALL-E 3",
  "author": "@Eearnest",
  "license": "MIT OR Apache-2.0",
  "auth": {
    "type": "bearer",
    "vault_key": "OPENAI_API_KEY",
    "header": "Authorization"
  },
  "allowed_endpoints": [
    "https://api.openai.com/v1/images/generations",
    "https://api.openai.com/v1/images/edits"
  ],
  "actions": [
    {
      "name": "generate_image",
      "description": "Generate an image from a text prompt using DALL-E 3",
      "parameters": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Text description of the image to generate",
            "maxLength": 4000
          },
          "size": {
            "type": "string",
            "description": "Image dimensions",
            "enum": ["1024x1024", "1792x1024", "1024x1792"],
            "default": "1024x1024"
          },
          "quality": {
            "type": "string",
            "description": "Image quality level",
            "enum": ["standard", "hd"],
            "default": "standard"
          },
          "style": {
            "type": "string",
            "description": "Visual style of the generated image",
            "enum": ["vivid", "natural"],
            "default": "vivid"
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL of the generated image"
          },
          "revised_prompt": {
            "type": "string",
            "description": "The prompt as revised by DALL-E"
          },
          "created": {
            "type": "integer",
            "description": "Unix timestamp of image creation"
          }
        }
      },
      "cost": "$0.04 standard / $0.08 HD per image",
      "requires_confirmation": true
    },
    {
      "name": "generate_image_hd",
      "description": "Generate a high-definition image from a text prompt",
      "parameters": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Text description of the image to generate",
            "maxLength": 4000
          },
          "size": {
            "type": "string",
            "enum": ["1024x1024", "1792x1024", "1024x1792"],
            "default": "1024x1024"
          },
          "style": {
            "type": "string",
            "enum": ["vivid", "natural"],
            "default": "vivid"
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "revised_prompt": { "type": "string" },
          "created": { "type": "integer" }
        }
      },
      "cost": "$0.08 per image",
      "requires_confirmation": true
    },
    {
      "name": "describe_and_generate",
      "description": "Takes a design goal in plain language, crafts an optimized DALL-E prompt internally, then generates the image",
      "parameters": {
        "type": "object",
        "required": ["goal"],
        "properties": {
          "goal": {
            "type": "string",
            "description": "Plain language description of the design goal",
            "maxLength": 1000
          },
          "style": {
            "type": "string",
            "enum": ["vivid", "natural"],
            "default": "vivid"
          },
          "size": {
            "type": "string",
            "enum": ["1024x1024", "1792x1024", "1024x1792"],
            "default": "1024x1024"
          },
          "quality": {
            "type": "string",
            "enum": ["standard", "hd"],
            "default": "standard"
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "prompt_used": { "type": "string" },
          "revised_prompt": { "type": "string" },
          "created": { "type": "integer" }
        }
      },
      "cost": "$0.04 standard / $0.08 HD per image",
      "requires_confirmation": true
    }
  ],
  "limits": {
    "max_images_per_call": 1,
    "max_prompt_length": 4000,
    "rate_limit": "50 per minute",
    "dry_run_supported": true
  },
  "security": {
    "credentials_in_vault_only": true,
    "no_key_in_output": true,
    "user_confirmation_required": true,
    "no_local_storage": true
  }
}
